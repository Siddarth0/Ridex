# Copy to .env and fill in. Never commit .env.
NODE_ENV=development
PORT=8000
FRONTEND_URL=http://localhost:3000

# Supabase Postgres connection string (Settings → Database → Connection string, URI)
# Use the "Transaction pooler" URI for the app.
DATABASE_URL=

# 32+ chars, generate with: openssl rand -hex 32
JWT_SECRET=

# Optional — without SMTP, verification/reset emails are logged to the console
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Optional — Supabase Storage for driver documents (falls back to local ./uploads)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
UPLOAD_DIR=./uploads

# Optional — OSM service overrides (public instances by default)
OSRM_URL=https://router.project-osrm.org
PHOTON_URL=https://photon.komoot.io
